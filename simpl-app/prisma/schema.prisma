// Last updated: 2026-04-21
// Changes: Replaced the demo blog schema with the Simpl domain model for posts, reactions, moderation, and anonymous actors.
// Purpose: Define the PostgreSQL data model used by the Next.js Simpl rebuild.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PostStatus {
  ACTIVE
  UNDER_REVIEW
  HIDDEN
  REMOVED
}

enum ReactionType {
  LIKE
  DISLIKE
}

enum ModerationDecision {
  KEEP
  REMOVE
}

model Actor {
  id              String           @id @default(cuid())
  key             String           @unique
  displayName     String
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  posts           Post[]
  reactions       Reaction[]
  moderationVotes ModerationVote[]

  @@map("simpl_actors")
}

model Post {
  id               String             @id @default(cuid())
  title            String
  body             String
  authorId         String
  parentId         String?
  rootId           String?
  latitude         Float?
  longitude        Float?
  likeCount        Int                @default(0)
  dislikeCount     Int                @default(0)
  reportCount      Int                @default(0)
  keepVoteCount    Int                @default(0)
  removeVoteCount  Int                @default(0)
  isHomepageVisible Boolean           @default(true)
  isInModeration    Boolean           @default(false)
  status           PostStatus         @default(ACTIVE)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  author           Actor              @relation(fields: [authorId], references: [id], onDelete: Restrict)
  parent           Post?              @relation("PostReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies          Post[]             @relation("PostReplies")
  root             Post?              @relation("PostThread", fields: [rootId], references: [id], onDelete: Cascade)
  threadPosts      Post[]             @relation("PostThread")
  reactions        Reaction[]
  moderationVotes  ModerationVote[]

  @@index([createdAt])
  @@index([parentId, createdAt])
  @@index([rootId, createdAt])
  @@index([isHomepageVisible, createdAt])
  @@index([isInModeration, removeVoteCount, createdAt])
  @@index([status, createdAt])
  @@map("simpl_posts")
}

model Reaction {
  id        String       @id @default(cuid())
  actorId   String
  postId    String
  type      ReactionType
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  actor     Actor        @relation(fields: [actorId], references: [id], onDelete: Cascade)
  post      Post         @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([actorId, postId])
  @@index([postId, type])
  @@map("simpl_reactions")
}

model ModerationVote {
  id        String             @id @default(cuid())
  actorId   String
  postId    String
  decision  ModerationDecision
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  actor     Actor              @relation(fields: [actorId], references: [id], onDelete: Cascade)
  post      Post               @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([actorId, postId])
  @@index([postId, decision])
  @@map("simpl_moderation_votes")
}